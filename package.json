{
  "name": "nova-desktop",
  "version": "1.0.0",
  "description": "Pika desktop app — native macOS wrapper for pika.me",
  "main": "main.js",
  "author": "Pika <hi@pika.me>",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "ai.pika.nova",
    "productName": "Pika",
    "copyright": "Copyright © 2026 Pika",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-sidebar.js",
      "renderer/**",
      "build/icon.icns",
      "build/icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  }
}
